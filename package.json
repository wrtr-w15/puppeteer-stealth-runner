    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "eslint": "^8.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.0.0"
  }
