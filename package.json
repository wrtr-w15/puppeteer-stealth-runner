{
  "name": "puppeteer-stealth-runner",
  "version": "1.0.0",
  "description": "Concurrent browser automation framework with isolated stealth profiles, built with TDD",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
